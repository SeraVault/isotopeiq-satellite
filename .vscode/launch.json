{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django (Docker)",
      "type": "debugpy",
      "request": "attach",
      "preLaunchTask": "Docker: Compose Up",
      "postDebugTask": "Docker: Compose Down",
      "connect": {
        "host": "localhost",
        "port": 5678
      },
      "pathMappings": [
        {
          "localRoot": "${workspaceFolder}/backend",
          "remoteRoot": "/app"
        }
      ],
      "django": true
    }
  ]
}
