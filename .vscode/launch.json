{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Django: Local",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/backend/manage.py",
      "args": ["runserver", "0.0.0.0:8000", "--noreload"],
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "django": true,
      "justMyCode": true,
      "python": "${workspaceFolder}/.venv/bin/python",
      "preLaunchTask": "Start All"
    }
  ]
}
